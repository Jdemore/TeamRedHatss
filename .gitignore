# Unity generated
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Memory captures
/[Mm]emoryCaptures/

# Recordings
/[Rr]ecordings/

# Asset meta auto-recovery
/[Aa]sset[Ss]tore[Tt]ools/

# Autogenerated VS/Rider solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed addressables
/[Aa]ddressables/

# ===========================
# OS
# ===========================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ===========================
# IDE
# ===========================

# JetBrains Rider
.idea/
*.iml

# Visual Studio
.vs/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/
*.code-workspace

# ===========================
# Project-specific
# ===========================

# Gradle (Android builds)
/[Bb]uild/
.gradle/
local.properties

# IL2CPP build cache
/il2cpp_cache/

# Oculus / Meta signing keys
*.keystore
*.jks
!*.keystore.meta

# Audio working files (keep only final exports)
*.audacity
*.aup3
*.aup
*_data/

# Blender / modeling working files
*.blend1
*.blend2
*.fbx.meta.bak

# Substance working files
*.spp
*.sbsar.meta.bak

# Large binary originals (use Git LFS or keep out of repo)
# Uncomment if NOT using Git LFS:
# *.wav
# *.psd
# *.tga
# *.tif
# *.tiff
# *.fbx
# *.obj
ProjectSettings/Packages/com.unity.learn.iet-framework/Settings.json
ProjectSettings/Packages/com.unity.testtools.codecoverage/Settings.json
Assets/XR/AndroidXR/AndroidXRSettingsInitializer
Assets/XR/Settings/OpenXR Package Settings.asset
